set -e

# gcc 4.4.0 (2009)
# C++ standard = gnu++0x: incomplete C++11 with gnu extensions
# WinCE 2.0+; architecture: ARMv4
# Required DLLs: gx.dll (only for default videodriver (gapi) - see sunvox_config.ini), aygshell.dll, ceshell.dll, coredll.dll

MAKE_OPTIONS="TARGET_OS=windowsce TARGET_ARCH=arm COLOR_TYPE=COLOR16BITS STYPE=PS_STYPE_INT16 CPPSTD=-std=gnu++0x"
make -j16 $MAKE_OPTIONS
make install $MAKE_OPTIONS
